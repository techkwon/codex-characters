{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Pet",
  "version": "0.1.0",
  "identifier": "com.highlearning.petreminder",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:ui",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex Pet Settings",
        "width": 760,
        "height": 680,
        "minWidth": 680,
        "minHeight": 560,
        "visible": false,
        "resizable": true
      },
      {
        "label": "pet",
        "title": "Pet",
        "width": 220,
        "height": 240,
        "visible": true,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/pets/**/*"
        ]
      },
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost data:",
        "connect-src": "ipc: http://ipc.localhost",
        "font-src": "'self'",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "msi",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Lightweight standalone Codex-compatible desktop pets.",
    "longDescription": "Codex Pet is a lightweight standalone desktop pet app with study reminders and Codex-compatible animated pet support."
  }
}
